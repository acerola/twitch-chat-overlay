# Default Twitch channel used when URL does not include ?channel=
VITE_CHANNEL_NAME=your_channel_name

# Enable debug menu and debug fixtures by default:
# 0 = disabled, 1 = enabled
VITE_DEBUG_MODE=1

# Twitch application client ID (optional)
# Enables EventSub power-ups (gigantified emotes, message effects, celebrations)
# Register at https://dev.twitch.tv/console with redirect URL:
# https://<your-username>.github.io/twitch-chat-overlay/?customize=1
VITE_TWITCH_CLIENT_ID=
